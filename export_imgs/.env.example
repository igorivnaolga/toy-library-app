# Copy to export_imgs/.env (same folder as export-imgs.py), or to the repo root as .env
# (scripts load root .env first, then export_imgs/.env overrides the same keys).
# In Chrome: DevTools → Application → Cookies → https://cctoylibrary.setls.co.nz
# Paste values below. Do not commit the real .env file.

# Cookie _mymibase_app_session (long value)
SETLS_SESSION_COOKIE=

# Cookie remember_token
SETLS_REMEMBER_TOKEN=
