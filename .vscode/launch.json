{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter Android (emulator, Supabase)",
      "request": "launch",
      "type": "dart",
      "program": "mobile/lib/main.dart",
      "cwd": "mobile",
      "args": [
        "--dart-define-from-file=env/dev.json"
      ],
      "toolArgs": [
        "--no-dds",
        "--host-vmservice-port=58162",
        "--device-timeout=120"
      ]
    },
    {
      "name": "Flutter Android (emulator, guest/no auth)",
      "request": "launch",
      "type": "dart",
      "program": "mobile/lib/main.dart",
      "cwd": "mobile",
      "args": [
        "--dart-define=USE_ADB_REVERSE=true"
      ],
      "toolArgs": [
        "--no-dds",
        "--host-vmservice-port=58162",
        "--device-timeout=120"
      ]
    }
  ]
}