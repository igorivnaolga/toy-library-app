# Supabase Postgres: Settings -> Database -> Connection string -> URI
# On Windows / IPv4-only networks, do NOT use db.<project>.supabase.co (IPv6-only).
# Use the **Session pooler** URI and keep the postgresql+psycopg:// prefix, e.g.:
# postgresql+psycopg://postgres.<project-ref>:YOUR_PASSWORD@aws-0-<region>.pooler.supabase.com:5432/postgres
# Leave empty for catalog-only local dev (CSV fallback; bookings/loans need a DB).
DATABASE_URL=
# Dev only: create tables on API startup (use migrations in production)
CREATE_TABLES_ON_STARTUP=true
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Supabase (Auth + JWT verification in FastAPI). Dashboard → Settings → API.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-api-settings
# Folder containing JPG/PNG files named like `photo_file` in the API (e.g. 142928.jpg).
# If unset, the API uses `<repo>/toy_library_photos` when that directory exists.
# TOY_IMAGES_DIR=C:\path\to\toy_library_photos
