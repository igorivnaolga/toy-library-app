# Supabase Postgres: Project Settings -> Database -> Connection string (URI)
# Example: postgresql+psycopg://postgres.xxx:YOUR_PASSWORD@aws-0-...pooler.supabase.com:6543/postgres
DATABASE_URL=
# Dev only: create tables on API startup (use migrations in production)
CREATE_TABLES_ON_STARTUP=true
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
