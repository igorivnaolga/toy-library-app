# Copy to .env.production locally (never commit). Set the same values on Railway/Render/Fly.
DATABASE_URL=postgresql+psycopg://postgres.YOUR_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
CREATE_TABLES_ON_STARTUP=false
CRON_SECRET=generate-a-long-random-string
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-api-settings
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional: mount Firebase JSON and set path for FCM push
# FIREBASE_CREDENTIALS_PATH=/app/firebase-service-account.json
